{
  "name": "immersive-focus-companion",
  "version": "0.2.1",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "desktop:dev": "electron .",
    "desktop:build": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "4.5.4"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "electron": "31.2.1",
    "electron-builder": "24.13.3",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.4",
    "typescript": "5.5.3"
  },
  "build": {
    "appId": "com.focus.companion.desktop",
    "productName": "ImmersiveFocusCompanion",
    "files": [
      "electron/**",
      ".next/standalone/**",
      ".next/static/**",
      "public/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "ImmersiveFocusCompanion-${version}.exe"
    },
    "asar": false
  }
}
